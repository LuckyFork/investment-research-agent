# ── App ──────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production

# ── LLM（Deepseek，兼容 OpenAI 接口）────────────────────
# 在 https://platform.deepseek.com 注册后获取
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=4096

# ── Embedding（OpenAI text-embedding-3-small）────────────
# 在 https://platform.openai.com/api-keys 获取
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_MODEL=text-embedding-3-small

# ── PostgreSQL ───────────────────────────────────────────
# 本地开发用 localhost；Docker Compose 内部用 postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=investment_research
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Redis ────────────────────────────────────────────────
# 本地开发用 localhost；Docker Compose 内部用 redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Qdrant ───────────────────────────────────────────────
# 本地开发用 localhost；Docker Compose 内部用 qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_DOCS=documents
QDRANT_COLLECTION_MEMORY=memory

# ── Celery ───────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── 文件上传目录 ──────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── OpenTelemetry（本地开发保持关闭）────────────────────
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=investment-research-agent
